# Converts the item if their cursor selects it. Player must pick up item for it to work.
execute if items entity @s player.cursor armadillo_scute run item modify entity @s player.cursor {function:"set_components","components":{"provides_trim_material":"more_colors:armadillo_scute","minecraft:custom_data":{converted:1b}}}
